{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/about", "destination": "/about.html", "permanent": true },
    { "source": "/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html", "permanent": true },
    { "source": "/disclaimer", "destination": "/disclaimer.html", "permanent": true },
    { "source": "/terms", "destination": "/terms.html", "permanent": true },
    { "source": "/background-remover", "destination": "/vertical-lab.html?category=bgremove", "permanent": true },
    { "source": "/text-to-video", "destination": "/vertical-lab.html?category=text2video", "permanent": true },
    { "source": "/keyword-research", "destination": "/vertical-lab.html?category=keywordresearch", "permanent": true }
  ]
}
